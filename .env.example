# ==============================================================
# VARIABLES DE ENTORNO — Weather Pro
# Copiá este archivo como ".env" y completá los valores reales
# NUNCA subas el archivo ".env" real a git (está en .gitignore)
# ==============================================================

# --- Django ---
SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria
DEBUG=False

# --- BigQuery ---
GOOGLE_APPLICATION_CREDENTIALS=credenciales/bigquery-credentials.json
BIGQUERY_PROJECT_ID=proyecto-bi-488218
OPENAI_API_KEY=tu_api_key_de_openai_aqui

# --- webhooks n8n ---
N8N_WEBHOOK_NAVAL=https://n8n-production-2651.up.railway.app/webhook/Naval_BI
N8N_WEBHOOK_AGRO=https://n8n-production-2651.up.railway.app/webhook/Agro_BI
N8N_WEBHOOK_AEREO=https://n8n-production-2651.up.railway.app/webhook/Aereo_BI
N8N_WEBHOOK_ENERGIA=https://n8n-production-2651.up.railway.app/webhook/Energia_BI
# Secreto compartido entre Django y n8n. Generá uno con: python -c "import secrets; print(secrets.token_hex(32))"
# Luego configurá la misma clave en n8n: Settings → Environment Variables → N8N_WEBHOOK_SECRET
N8N_WEBHOOK_SECRET=cambia-esto-por-un-token-aleatorio-largo

# --- Sitio (URL pública para callbacks de pago) ---
SITE_URL=https://tudominio.com

# ==============================================================
# PAYPAL
# Para PRUEBAS     → MODE=sandbox + credenciales de sandbox
# Para PRODUCCIÓN  → MODE=live    + credenciales live
#
# Cómo obtener credenciales LIVE:
#   1. Ir a https://developer.paypal.com/dashboard/
#   2. Apps & Credentials → pestaña "Live" (NO "Sandbox")
#   3. Crear o seleccionar una app Live
#   4. Copiar Client ID y Secret de la sección "Live"
# ==============================================================
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=reemplazar_con_client_id_de_sandbox_o_live
PAYPAL_CLIENT_SECRET=reemplazar_con_secret_de_sandbox_o_live

# ==============================================================
# LEMON SQUEEZY
# LEMONSQUEEZY_STORE_SLUG: el slug de tu tienda (ej: "tuclima")
#   lo ves en la URL del checkout: tuclima.lemonsqueezy.com
# LEMONSQUEEZY_WEBHOOK_SECRET: lo seteás en LS → Settings → Webhooks
# ==============================================================
LEMONSQUEEZY_STORE_SLUG=tuclima
LEMONSQUEEZY_WEBHOOK_SECRET=whsec_reemplazar_con_el_secreto_del_webhook

# ==============================================================
# MERCADOPAGO
# Para PRUEBAS     → usar Access Token TEST-...
# Para PRODUCCIÓN  → usar Access Token APP_USR-...
#
# Cómo obtener:
#   1. https://www.mercadopago.com.ar/developers/panel
#   2. Tu aplicación → Credenciales de producción
#   3. Copiar "Access Token"
# ==============================================================
MP_ACCESS_TOKEN=TEST-reemplazar-con-access-token-real

# ==============================================================
# EMAIL (Gmail SMTP)
# Requiere "Contraseña de aplicación" (NO la contraseña normal):
#   https://myaccount.google.com/apppasswords
# ==============================================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=tucorreo@gmail.com
EMAIL_HOST_PASSWORD=contraseña_de_aplicacion_16_caracteres
DEFAULT_FROM_EMAIL=Weather Pro <tucorreo@gmail.com>

# ==============================================================
# CHECKLIST PARA IR A PRODUCCIÓN
# [ ] Obtener Client ID y Secret LIVE en developer.paypal.com
# [ ] Cambiar PAYPAL_MODE=live
# [ ] Cambiar MP_ACCESS_TOKEN al token de producción (APP_USR-...)
# [ ] Cambiar SITE_URL a la URL pública real del servidor
# [ ] Verificar que DEBUG=False
# [ ] Verificar que el dominio esté configurado en webhooks de MP
# ==============================================================