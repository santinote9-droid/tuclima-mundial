# Variables de entorno necesarias para la funcionalidad multisectorial
# Copiar este archivo como .env y configurar las variables apropiadas

# OpenAI API Key para análisis con IA
OPENAI_API_KEY=tu_api_key_de_openai_aqui

# Google Cloud BigQuery (ya configurado en tu proyecto)
GOOGLE_APPLICATION_CREDENTIALS=ruta_a_tu_service_account.json
BIGQUERY_PROJECT_ID=proyecto-bi-488218

# URLs de webhooks n8n para envío desde Django
N8N_WEBHOOK_NAVAL=https://n8n-production-2651.up.railway.app/webhook/Naval_BI
N8N_WEBHOOK_AGRO=https://n8n-production-2651.up.railway.app/webhook/Agro_BI
N8N_WEBHOOK_AEREO=https://n8n-production-2651.up.railway.app/webhook/Aereo_BI
N8N_WEBHOOK_ENERGIA=https://n8n-production-2651.up.railway.app/webhook/Energia_BI

# Configuración de Django para desarrollo
DEBUG=True
SECRET_KEY=tu_secret_key_aqui

# Base de datos (opcional si usas diferente a SQLite)
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname